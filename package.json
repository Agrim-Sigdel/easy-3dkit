{
  "name": "easy-3dkit",
  "version": "0.3.0",
  "description": "A reusable library of interactive 3D components for React (R3F + three.js + GSAP)",
  "type": "module",
  "license": "MIT",
  "author": "Agrim-Sigdel",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agrim-Sigdel/easy-3dkit.git"
  },
  "homepage": "https://agrimsigdel.com.np/",
  "bugs": {
    "url": "https://github.com/Agrim-Sigdel/easy-3dkit/issues"
  },
  "keywords": [
    "react",
    "three",
    "r3f",
    "react-three-fiber",
    "3d",
    "ui-kit",
    "shaders",
    "webgl",
    "gsap"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./postprocessing": {
      "types": "./dist/postprocessing.d.ts",
      "import": "./dist/postprocessing.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:site": "tsc -b && vite build && node scripts/spa-fallback.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.mjs",
    "smoke:nogl": "node scripts/smoke-nogl.mjs",
    "docs:effects": "node scripts/gen-effects-docs.mjs",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:types": "tsc -p tsconfig.lib.json",
    "build:pkg": "npm run build:lib && npm run build:types",
    "check:pack": "node scripts/check-pack.mjs",
    "measure:size": "node scripts/measure-size.mjs",
    "sync:starter": "node scripts/sync-starter-template.mjs",
    "smoke:starter": "node scripts/smoke-starter.mjs",
    "check:nextjs": "node scripts/check-nextjs.mjs",
    "verify:dogfood": "E3DK_USE_DIST=1 vite build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepublishOnly": "npm run build:pkg"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9.114.0",
    "@react-three/fiber": ">=8.17.10",
    "@react-three/postprocessing": ">=2.16.3",
    "gsap": ">=3.12.5",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.169.0"
  },
  "peerDependenciesMeta": {
    "@react-three/postprocessing": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "@react-three/test-renderer": "^8.2.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.2",
    "esbuild": "^0.28.1",
    "gsap": "^3.12.5",
    "jsdom": "^29.1.1",
    "leva": "^0.9.35",
    "puppeteer-core": "^25.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "three": "^0.169.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.9"
  }
}
